[
  {
    "id": "bk_tai_0",
    "text": "わたしはすしが食べたいです。"
  },
  {
    "id": "bk_tai_1",
    "text": "日本へ行きたいです。"
  },
  {
    "id": "bk_tai_2",
    "text": "冷たい水が飲みたいです。"
  },
  {
    "id": "bk_tekudasai_0",
    "text": "ここに名前を書いてください。"
  },
  {
    "id": "bk_tekudasai_1",
    "text": "ちょっと待ってください。"
  },
  {
    "id": "bk_tekudasai_2",
    "text": "ゆっくり話してください。"
  },
  {
    "id": "bk_teimasu_0",
    "text": "今ご飯を食べています。"
  },
  {
    "id": "bk_teimasu_1",
    "text": "父は新聞を読んでいます。"
  },
  {
    "id": "bk_teimasu_2",
    "text": "子どもたちが公園で遊んでいます。"
  },
  {
    "id": "bk_temoii_0",
    "text": "ここで写真を撮ってもいいですか。"
  },
  {
    "id": "bk_temoii_1",
    "text": "トイレに行ってもいいですか。"
  },
  {
    "id": "bk_temoii_2",
    "text": "ここに座ってもいいですよ。"
  },
  {
    "id": "bk_tewaikenai_0",
    "text": "ここでタバコを吸ってはいけません。"
  },
  {
    "id": "bk_tewaikenai_1",
    "text": "写真を撮ってはいけません。"
  },
  {
    "id": "bk_tewaikenai_2",
    "text": "ここに車を止めてはいけません。"
  },
  {
    "id": "bk_naide_0",
    "text": "ここで写真を撮らないでください。"
  },
  {
    "id": "bk_naide_1",
    "text": "心配しないでください。"
  },
  {
    "id": "bk_naide_2",
    "text": "ここに入らないでください。"
  },
  {
    "id": "bk_mashou_0",
    "text": "一緒に帰りましょう。"
  },
  {
    "id": "bk_mashou_1",
    "text": "ちょっと休みましょう。"
  },
  {
    "id": "bk_mashou_2",
    "text": "一緒に昼ご飯を食べましょう。"
  },
  {
    "id": "bk_nagara_0",
    "text": "音楽を聞きながら勉強します。"
  },
  {
    "id": "bk_nagara_1",
    "text": "テレビを見ながらご飯を食べます。"
  },
  {
    "id": "bk_nagara_2",
    "text": "コーヒーを飲みながら話しましょう。"
  },
  {
    "id": "bk_tekara_0",
    "text": "手を洗ってからご飯を食べます。"
  },
  {
    "id": "bk_tekara_1",
    "text": "宿題をしてから遊びます。"
  },
  {
    "id": "bk_tekara_2",
    "text": "お風呂に入ってから寝ます。"
  },
  {
    "id": "bk_takoto_0",
    "text": "日本へ行ったことがあります。"
  },
  {
    "id": "bk_takoto_1",
    "text": "富士山に登ったことがあります。"
  },
  {
    "id": "bk_takoto_2",
    "text": "すしを食べたことがあります。"
  },
  {
    "id": "bk_nakereba_0",
    "text": "明日早く起きなければなりません。"
  },
  {
    "id": "bk_nakereba_1",
    "text": "薬を飲まなければなりません。"
  },
  {
    "id": "bk_nakereba_2",
    "text": "宿題をしなければなりません。"
  },
  {
    "id": "bk_taritari_0",
    "text": "休みの日は本を読んだり音楽を聞いたりします。"
  },
  {
    "id": "bk_taritari_1",
    "text": "パーティーで歌ったり踊ったりしました。"
  },
  {
    "id": "bk_taritari_2",
    "text": "日曜日は掃除したり洗濯したりします。"
  }
]