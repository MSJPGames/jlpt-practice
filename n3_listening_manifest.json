{
  "voices": {
    "N": "ja-JP-NanamiNeural (low/slow)",
    "F": "ja-JP-NanamiNeural (higher)",
    "M": "ja-JP-KeitaNeural",
    "note": "edge-tts has only Nanami/Keita for JP; narrator set apart by pitch/rate in the .py"
  },
  "items": [
    {
      "file": "n3_q1_01.mp3",
      "segments": [
        {
          "role": "N",
          "text": "会社で、女の人と男の人が話しています。"
        },
        {
          "role": "F",
          "text": "この資料、明日の会議で使うんです。コピーをお願いできますか。"
        },
        {
          "role": "M",
          "text": "はい。何部いりますか。"
        },
        {
          "role": "F",
          "text": "十部お願いします。あ、でも、その前に部長に内容を確認してもらってからにしてください。"
        },
        {
          "role": "M",
          "text": "わかりました。じゃあ、先に部長に見せますね。"
        },
        {
          "role": "N",
          "text": "男の人は、まず初めに何をしますか。"
        }
      ]
    },
    {
      "file": "n3_q1_02.mp3",
      "segments": [
        {
          "role": "N",
          "text": "電話で、妻と夫が話しています。"
        },
        {
          "role": "F",
          "text": "もしもし。今、駅に着いたんだけど、電車が止まっていて、帰るのが遅くなりそうなの。"
        },
        {
          "role": "M",
          "text": "え、大丈夫？"
        },
        {
          "role": "F",
          "text": "うん。悪いんだけど、洗濯物を外に干してあるから、取り込んでおいてくれる？　雨が降りそうだから。"
        },
        {
          "role": "M",
          "text": "わかった。晩ごはんは？"
        },
        {
          "role": "F",
          "text": "それは買って帰るから大丈夫。"
        },
        {
          "role": "N",
          "text": "夫は、このあとまず何をしますか。"
        }
      ]
    },
    {
      "file": "n3_q1_03.mp3",
      "segments": [
        {
          "role": "N",
          "text": "大学で、先生と学生が話しています。"
        },
        {
          "role": "M",
          "text": "レポートは金曜日までに出してください。メールでも紙でもいいですよ。"
        },
        {
          "role": "F",
          "text": "先生、実はパソコンが壊れてしまって、印刷ができないんです。"
        },
        {
          "role": "M",
          "text": "じゃあ、メールで送ってください。それも難しければ、月曜日に紙で持ってきてもいいですよ。"
        },
        {
          "role": "F",
          "text": "いえ、メールなら送れます。今日中に送ります。"
        },
        {
          "role": "N",
          "text": "学生は、このあとどうしますか。"
        }
      ]
    },
    {
      "file": "n3_q2_01.mp3",
      "segments": [
        {
          "role": "N",
          "text": "男の人と女の人が話しています。"
        },
        {
          "role": "M",
          "text": "田中さん、昨日のパーティー、来なかったね。どうしたの？"
        },
        {
          "role": "F",
          "text": "ごめん、行きたかったんだけど…。"
        },
        {
          "role": "M",
          "text": "仕事が忙しかった？"
        },
        {
          "role": "F",
          "text": "ううん、仕事は休みだったの。実は、朝から頭が痛くて、病院に行っていたんだ。"
        },
        {
          "role": "M",
          "text": "え、大丈夫？"
        },
        {
          "role": "F",
          "text": "うん、薬をもらって、もう良くなったよ。"
        },
        {
          "role": "N",
          "text": "女の人は、どうしてパーティーに行きませんでしたか。"
        }
      ]
    },
    {
      "file": "n3_q2_02.mp3",
      "segments": [
        {
          "role": "N",
          "text": "クリーニング店で、女の人と店員が話しています。"
        },
        {
          "role": "F",
          "text": "すみません、このシャツ、明日までにお願いできますか。"
        },
        {
          "role": "M",
          "text": "明日ですか。お急ぎですと、いつもより三百円高くなりますが、よろしいですか。"
        },
        {
          "role": "F",
          "text": "うーん、三百円か…。じゃあ、普通だといつできますか。"
        },
        {
          "role": "M",
          "text": "あさってになります。"
        },
        {
          "role": "F",
          "text": "じゃあ、急がなくていいです。あさってでお願いします。"
        },
        {
          "role": "N",
          "text": "女の人は、どうして急ぎのコースにしませんでしたか。"
        }
      ]
    },
    {
      "file": "n3_q2_03.mp3",
      "segments": [
        {
          "role": "N",
          "text": "男の人と女の人が、旅行について話しています。"
        },
        {
          "role": "F",
          "text": "夏休み、北海道に行くって言ってたよね。飛行機で行くの？"
        },
        {
          "role": "M",
          "text": "いや、車で行くことにしたんだ。"
        },
        {
          "role": "F",
          "text": "え、遠いのに。飛行機のほうがずっと早いでしょ。"
        },
        {
          "role": "M",
          "text": "うん。でも、途中でいろいろな町に寄りたくて。景色を見ながら、ゆっくり行きたいんだ。"
        },
        {
          "role": "F",
          "text": "なるほどね。"
        },
        {
          "role": "N",
          "text": "男の人は、どうして車で行きますか。"
        }
      ]
    },
    {
      "file": "n3_q3_01.mp3",
      "segments": [
        {
          "role": "N",
          "text": "ラジオで、女の人が話しています。"
        },
        {
          "role": "F",
          "text": "私は十年間、毎朝走っています。始めたころは、やせたいという理由だけでした。でも、続けているうちに、体の調子が良くなり、夜もよく眠れるようになりました。今では、走らないと一日が始まらない気がします。走ることは、もう私の生活の一部になっているんです。"
        },
        {
          "role": "N",
          "text": "女の人が一番言いたいことは、何ですか。"
        }
      ]
    },
    {
      "file": "n3_q3_02.mp3",
      "segments": [
        {
          "role": "N",
          "text": "テレビで、店の人が話しています。"
        },
        {
          "role": "M",
          "text": "うちの店では、野菜はすべて近くの農家から仕入れています。スーパーより少し高いかもしれません。でも、その日の朝に取れたばかりの新鮮な野菜が並びます。お客様には、作った人の顔が見える、安心な野菜を食べてほしいんです。だから、これからもこのやり方を続けていきます。"
        },
        {
          "role": "N",
          "text": "店の人は、何について話していますか。"
        }
      ]
    },
    {
      "file": "n3_q3_03.mp3",
      "segments": [
        {
          "role": "N",
          "text": "会社で、先輩が新入社員に話しています。"
        },
        {
          "role": "F",
          "text": "仕事で分からないことがあったら、すぐに聞いてね。最初はだれでも失敗するから、失敗を怖がらなくていいよ。でも、同じ失敗を二度しないように、聞いたことは必ずメモを取ること。それが一番大事なの。メモを見返せば、少しずつできることが増えていくからね。"
        },
        {
          "role": "N",
          "text": "先輩が一番伝えたいことは、何ですか。"
        }
      ]
    },
    {
      "file": "n3_q4_01.mp3",
      "segments": [
        {
          "role": "N",
          "text": "電車の中で、お年寄りが立っています。あなたは席に座っています。席をゆずりたいです。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_02.mp3",
      "segments": [
        {
          "role": "N",
          "text": "友だちに借りた本を、うっかり少し破いてしまいました。本を返すとき、正直に伝えます。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_03.mp3",
      "segments": [
        {
          "role": "N",
          "text": "駅で、道が分からず困っている様子の人がいます。あなたは手伝いたいです。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q5_01.mp3",
      "segments": [
        {
          "role": "M",
          "text": "その本、読み終わったら貸してくれない？"
        }
      ]
    },
    {
      "file": "n3_q5_02.mp3",
      "segments": [
        {
          "role": "M",
          "text": "いらっしゃいませ。何かお探しですか。"
        }
      ]
    },
    {
      "file": "n3_q5_03.mp3",
      "segments": [
        {
          "role": "F",
          "text": "この資料、ちょっと分かりにくいんだけど、直してもらえる？"
        }
      ]
    },
    {
      "file": "n3_q1_04.mp3",
      "segments": [
        {
          "role": "N",
          "text": "学校で、先生と学生が話しています。学生は、このあとまず何をしますか。"
        },
        {
          "role": "M",
          "text": "来週の発表の準備はどうですか。"
        },
        {
          "role": "F",
          "text": "はい、資料はほとんどできました。あとは、当日使うパソコンを予約するだけです。"
        },
        {
          "role": "M",
          "text": "パソコンの予約の前に、発表の内容をもう一度私に見せてください。直すところがあるかもしれません。"
        },
        {
          "role": "F",
          "text": "分かりました。じゃあ、すぐにお見せします。"
        },
        {
          "role": "N",
          "text": "学生は、このあとまず何をしますか。"
        }
      ]
    },
    {
      "file": "n3_q1_05.mp3",
      "segments": [
        {
          "role": "N",
          "text": "家で、母と息子が話しています。息子は、まず何をしますか。"
        },
        {
          "role": "F",
          "text": "スーパーに行く前に、冷蔵庫に何が残っているか見てくれる？"
        },
        {
          "role": "M",
          "text": "うん、いいよ。牛乳と卵を見ればいい？"
        },
        {
          "role": "F",
          "text": "そう。あと、リストを書いてから行ってね。無駄なものを買わないように。"
        },
        {
          "role": "M",
          "text": "分かった。じゃあ先に冷蔵庫を見て、それからリストを書くね。"
        },
        {
          "role": "N",
          "text": "息子は、まず何をしますか。"
        }
      ]
    },
    {
      "file": "n3_q1_06.mp3",
      "segments": [
        {
          "role": "N",
          "text": "会社で、女の人と男の人が話しています。男の人は、まず何をしますか。"
        },
        {
          "role": "F",
          "text": "午後の会議、会議室の準備をお願いできる？"
        },
        {
          "role": "M",
          "text": "はい。いすを並べて、資料を配っておけばいいですか。"
        },
        {
          "role": "F",
          "text": "うん。あ、その前に、エアコンをつけて部屋を涼しくしておいて。今日は暑いから。"
        },
        {
          "role": "M",
          "text": "分かりました。じゃあ、まずエアコンをつけますね。"
        },
        {
          "role": "N",
          "text": "男の人は、まず何をしますか。"
        }
      ]
    },
    {
      "file": "n3_q2_04.mp3",
      "segments": [
        {
          "role": "N",
          "text": "電話で、男の人とレストランの店員が話しています。男の人は、どうして予約の時間を変えますか。"
        },
        {
          "role": "M",
          "text": "すみません、今日7時に予約した田中ですが、時間を8時に変えられますか。"
        },
        {
          "role": "F",
          "text": "はい、大丈夫ですよ。お仕事が遅くなりそうですか。"
        },
        {
          "role": "M",
          "text": "いえ、仕事は大丈夫なんですが、一緒に行く友だちの電車が事故で遅れているんです。"
        },
        {
          "role": "F",
          "text": "そうですか。では、8時にお待ちしております。"
        },
        {
          "role": "N",
          "text": "男の人は、どうして予約の時間を変えますか。"
        }
      ]
    },
    {
      "file": "n3_q2_05.mp3",
      "segments": [
        {
          "role": "N",
          "text": "女の人と男の人が話しています。女の人は、どうして引っ越しますか。"
        },
        {
          "role": "M",
          "text": "来月、引っ越すんだって？今のアパート、駅から近くて便利なのに。"
        },
        {
          "role": "F",
          "text": "うん。便利なんだけど、部屋がせまくてね。荷物が増えて、入りきらなくなっちゃって。"
        },
        {
          "role": "M",
          "text": "ああ、なるほど。じゃあ、次は広い部屋？"
        },
        {
          "role": "F",
          "text": "そう。少し駅から遠くなるけど、広いところにしたんだ。"
        },
        {
          "role": "N",
          "text": "女の人は、どうして引っ越しますか。"
        }
      ]
    },
    {
      "file": "n3_q2_06.mp3",
      "segments": [
        {
          "role": "N",
          "text": "会社で、男の人と女の人が話しています。男の人は、どうして遅刻しましたか。"
        },
        {
          "role": "F",
          "text": "田中さん、今日は遅かったですね。寝坊ですか。"
        },
        {
          "role": "M",
          "text": "いえ、ちゃんと早く家を出たんです。でも、途中で財布を忘れたことに気づいて、取りに戻ったんです。"
        },
        {
          "role": "F",
          "text": "ああ、それは大変でしたね。"
        },
        {
          "role": "N",
          "text": "男の人は、どうして遅刻しましたか。"
        }
      ]
    },
    {
      "file": "n3_q3_04.mp3",
      "segments": [
        {
          "role": "N",
          "text": "図書館で、係の人が話しています。"
        },
        {
          "role": "F",
          "text": "皆さんにお願いです。館内では、静かにお願いします。また、飲み物や食べ物は持ち込まないでください。本を汚してしまうことがあります。借りた本は、二週間以内に返してください。もし遅れそうなときは、電話で連絡していただければ、期間をのばすことができます。"
        },
        {
          "role": "N",
          "text": "係の人は、何について話していますか。"
        }
      ]
    },
    {
      "file": "n3_q3_05.mp3",
      "segments": [
        {
          "role": "N",
          "text": "女の人が話しています。"
        },
        {
          "role": "F",
          "text": "私は先月、初めて一人で旅行に行きました。最初は不安でした。でも、行ってみると、自分で全部決められるのがとても楽しかったです。道が分からないときは、地元の人に聞いて、いろいろな人と話すこともできました。一人旅は、さびしいと思っていましたが、思っていたよりずっといい経験でした。"
        },
        {
          "role": "N",
          "text": "女の人が一番言いたいことは、何ですか。"
        }
      ]
    },
    {
      "file": "n3_q3_06.mp3",
      "segments": [
        {
          "role": "N",
          "text": "学校で、先生が話しています。"
        },
        {
          "role": "M",
          "text": "今日の宿題について説明します。教科書の50ページを読んで、分からない言葉を調べてきてください。全部覚える必要はありません。大切なのは、自分で調べる習慣をつけることです。答えを写すだけでは、力はつきません。少し時間がかかっても、自分で辞書を引いてみてください。"
        },
        {
          "role": "N",
          "text": "先生が一番伝えたいことは、何ですか。"
        }
      ]
    },
    {
      "file": "n3_q4_04.mp3",
      "segments": [
        {
          "role": "N",
          "text": "授業中、ペンを忘れました。となりの友だちから借りたいです。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_05.mp3",
      "segments": [
        {
          "role": "N",
          "text": "会議に少し遅れてしまいました。部屋に入るとき、何と言いますか。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_06.mp3",
      "segments": [
        {
          "role": "N",
          "text": "服の店で、気に入ったシャツがありました。着てみたいです。店員に何と言いますか。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q5_04.mp3",
      "segments": [
        {
          "role": "M",
          "text": "重い荷物、運んでくれてありがとう。助かったよ。"
        }
      ]
    },
    {
      "file": "n3_q5_05.mp3",
      "segments": [
        {
          "role": "F",
          "text": "よかったら、一緒にお昼ごはんを食べに行かない？"
        }
      ]
    },
    {
      "file": "n3_q5_06.mp3",
      "segments": [
        {
          "role": "M",
          "text": "その仕事、大変そうですね。よかったら、私がやりましょうか。"
        }
      ]
    },
    {
      "file": "n3_q5_07.mp3",
      "segments": [
        {
          "role": "F",
          "text": "明日、引っ越しを手伝ってくれない？"
        }
      ]
    },
    {
      "file": "n3_q5_08.mp3",
      "segments": [
        {
          "role": "M",
          "text": "お先に失礼します。"
        }
      ]
    },
    {
      "file": "n3_q5_09.mp3",
      "segments": [
        {
          "role": "F",
          "text": "すみません、この席、空いていますか。"
        }
      ]
    },
    {
      "file": "n3_q5_10.mp3",
      "segments": [
        {
          "role": "F",
          "text": "窓を開けてもいいですか。"
        }
      ]
    },
    {
      "file": "n3_q5_11.mp3",
      "segments": [
        {
          "role": "F",
          "text": "コーヒー、もう一杯いかがですか。"
        }
      ]
    },
    {
      "file": "n3_q5_12.mp3",
      "segments": [
        {
          "role": "F",
          "text": "駅まで、どのくらいかかりますか。"
        }
      ]
    },
    {
      "file": "n3_q5_13.mp3",
      "segments": [
        {
          "role": "F",
          "text": "昨日のテスト、どうだった？"
        }
      ]
    },
    {
      "file": "n3_q5_14.mp3",
      "segments": [
        {
          "role": "F",
          "text": "これ、コピーしておいてくれる？"
        }
      ]
    },
    {
      "file": "n3_q5_15.mp3",
      "segments": [
        {
          "role": "F",
          "text": "お名前を教えていただけますか。"
        }
      ]
    },
    {
      "file": "n3_q5_16.mp3",
      "segments": [
        {
          "role": "F",
          "text": "電話が少し遠いんですが。"
        }
      ]
    },
    {
      "file": "n3_q5_17.mp3",
      "segments": [
        {
          "role": "F",
          "text": "もう帰ってもいいですか。"
        }
      ]
    },
    {
      "file": "n3_q5_18.mp3",
      "segments": [
        {
          "role": "F",
          "text": "手伝いましょうか。"
        }
      ]
    },
    {
      "file": "n3_q5_19.mp3",
      "segments": [
        {
          "role": "F",
          "text": "今、ちょっと時間ある？"
        }
      ]
    },
    {
      "file": "n3_q5_20.mp3",
      "segments": [
        {
          "role": "F",
          "text": "遅れて、すみません。"
        }
      ]
    },
    {
      "file": "n3_q5_21.mp3",
      "segments": [
        {
          "role": "F",
          "text": "この荷物、どこに置けばいいですか。"
        }
      ]
    },
    {
      "file": "n3_q5_22.mp3",
      "segments": [
        {
          "role": "F",
          "text": "少し熱があるみたいなんです。"
        }
      ]
    },
    {
      "file": "n3_q5_23.mp3",
      "segments": [
        {
          "role": "F",
          "text": "お茶とコーヒー、どちらになさいますか。"
        }
      ]
    },
    {
      "file": "n3_q5_24.mp3",
      "segments": [
        {
          "role": "F",
          "text": "宿題、もう終わった？"
        }
      ]
    },
    {
      "file": "n3_q5_25.mp3",
      "segments": [
        {
          "role": "F",
          "text": "荷物、持ちましょうか。"
        }
      ]
    },
    {
      "file": "n3_q5_26.mp3",
      "segments": [
        {
          "role": "F",
          "text": "この本、借りてもいいですか。"
        }
      ]
    },
    {
      "file": "n3_q5_27.mp3",
      "segments": [
        {
          "role": "F",
          "text": "明日は何時に集合ですか。"
        }
      ]
    },
    {
      "file": "n3_q5_28.mp3",
      "segments": [
        {
          "role": "F",
          "text": "体の調子はどうですか。"
        }
      ]
    },
    {
      "file": "n3_q5_29.mp3",
      "segments": [
        {
          "role": "F",
          "text": "すみません、ペンを貸してもらえますか。"
        }
      ]
    },
    {
      "file": "n3_q5_30.mp3",
      "segments": [
        {
          "role": "F",
          "text": "今日は本当にありがとうございました。"
        }
      ]
    },
    {
      "file": "n3_q4_07.mp3",
      "segments": [
        {
          "role": "N",
          "text": "友だちの家に着いて、げんかんから中に入ります。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_08.mp3",
      "segments": [
        {
          "role": "N",
          "text": "レストランで料理が来て、食べ始めます。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_09.mp3",
      "segments": [
        {
          "role": "N",
          "text": "道で人に軽くぶつかってしまいました。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_10.mp3",
      "segments": [
        {
          "role": "N",
          "text": "友だちがプレゼントをくれました。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_11.mp3",
      "segments": [
        {
          "role": "N",
          "text": "知らない道で、駅の場所を人に聞きたいです。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_12.mp3",
      "segments": [
        {
          "role": "N",
          "text": "店で店員を呼んで、注文したいです。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_13.mp3",
      "segments": [
        {
          "role": "N",
          "text": "相手の名前がよく聞こえませんでした。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_14.mp3",
      "segments": [
        {
          "role": "N",
          "text": "借りていた本を、友だちに返します。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_15.mp3",
      "segments": [
        {
          "role": "N",
          "text": "重い荷物を持っている人を手伝いたいです。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_16.mp3",
      "segments": [
        {
          "role": "N",
          "text": "知らない人に、写真を撮ってほしいと頼みます。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_17.mp3",
      "segments": [
        {
          "role": "N",
          "text": "かぜをひいて休んでいた友だちに会いました。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_18.mp3",
      "segments": [
        {
          "role": "N",
          "text": "約束の時間に遅れて、相手のところに着きました。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_19.mp3",
      "segments": [
        {
          "role": "N",
          "text": "試験に合格した友だちに、お祝いを言います。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_20.mp3",
      "segments": [
        {
          "role": "N",
          "text": "友だちと別れるとき、また会う約束をします。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_21.mp3",
      "segments": [
        {
          "role": "N",
          "text": "電話をかけて、自分の名前を言います。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q4_22.mp3",
      "segments": [
        {
          "role": "N",
          "text": "エレベーターで、あとから乗る人のためにボタンを押して待ちます。"
        },
        {
          "role": "N",
          "text": "こんなとき、何と言いますか。"
        }
      ]
    },
    {
      "file": "n3_q1_07.mp3",
      "segments": [
        {
          "role": "N",
          "text": "病院で、受付の人と男の人が話しています。男の人は、まず何をしますか。"
        },
        {
          "role": "F",
          "text": "こんにちは。初めてですか。"
        },
        {
          "role": "M",
          "text": "はい、初めてです。"
        },
        {
          "role": "F",
          "text": "では、まずこの紙に、お名前と住所を書いてください。書いたら、保険証と一緒に出してくださいね。"
        },
        {
          "role": "M",
          "text": "分かりました。"
        },
        {
          "role": "N",
          "text": "男の人は、まず何をしますか。"
        }
      ]
    },
    {
      "file": "n3_q1_08.mp3",
      "segments": [
        {
          "role": "N",
          "text": "会社で、女の人と男の人が話しています。女の人は、このあとまず何をしますか。"
        },
        {
          "role": "M",
          "text": "来週の出張の準備、進んでる？"
        },
        {
          "role": "F",
          "text": "はい。新幹線のチケットは取りました。あとはホテルの予約だけです。"
        },
        {
          "role": "M",
          "text": "ホテルの前に、部長に出張の予定を伝えておいて。急に変わるかもしれないから。"
        },
        {
          "role": "F",
          "text": "分かりました。では、先に部長に伝えます。"
        },
        {
          "role": "N",
          "text": "女の人は、このあとまず何をしますか。"
        }
      ]
    },
    {
      "file": "n3_q1_09.mp3",
      "segments": [
        {
          "role": "N",
          "text": "家で、女の人と男の人が話しています。男の人は、まず何をしますか。"
        },
        {
          "role": "F",
          "text": "カレー、作るの手伝ってくれる？"
        },
        {
          "role": "M",
          "text": "うん。野菜を切ればいい？"
        },
        {
          "role": "F",
          "text": "うん、でもその前に手をよく洗ってね。"
        },
        {
          "role": "M",
          "text": "あ、そうだね。じゃあ手を洗ってから切るよ。"
        },
        {
          "role": "N",
          "text": "男の人は、まず何をしますか。"
        }
      ]
    },
    {
      "file": "n3_q1_10.mp3",
      "segments": [
        {
          "role": "N",
          "text": "大学で、先生と学生が話しています。学生は、このあとまず何をしますか。"
        },
        {
          "role": "F",
          "text": "先生、レポートのことで相談があるんですが。"
        },
        {
          "role": "M",
          "text": "はい。でも、その前にこのプリントを読んできましたか。"
        },
        {
          "role": "F",
          "text": "あ、まだです。"
        },
        {
          "role": "M",
          "text": "じゃあ、まずそれを読んでから、また来てください。読めば分かることもありますよ。"
        },
        {
          "role": "F",
          "text": "分かりました。読んできます。"
        },
        {
          "role": "N",
          "text": "学生は、このあとまず何をしますか。"
        }
      ]
    },
    {
      "file": "n3_q2_07.mp3",
      "segments": [
        {
          "role": "N",
          "text": "男の人と女の人が話しています。男の人は、どうして昨日の映画に行きませんでしたか。"
        },
        {
          "role": "F",
          "text": "昨日の映画、どうだった？"
        },
        {
          "role": "M",
          "text": "それが、行けなかったんだ。"
        },
        {
          "role": "F",
          "text": "え、チケット買ってたのに。仕事？"
        },
        {
          "role": "M",
          "text": "ううん、仕事は早く終わったんだけど、急に弟が家に来て、いっしょにいることになって。"
        },
        {
          "role": "N",
          "text": "男の人は、どうして昨日の映画に行きませんでしたか。"
        }
      ]
    },
    {
      "file": "n3_q2_08.mp3",
      "segments": [
        {
          "role": "N",
          "text": "店で、女の人と店員が話しています。女の人は、どうしてこのくつを買いませんか。"
        },
        {
          "role": "F",
          "text": "このくつ、色もデザインもすごく好きなんですけど…。"
        },
        {
          "role": "M",
          "text": "ありがとうございます。サイズはいかがですか。"
        },
        {
          "role": "F",
          "text": "それが、少し小さくて。歩くと痛くなりそうなんです。"
        },
        {
          "role": "M",
          "text": "そうですか。ほかのサイズは、今ちょうど売り切れておりまして。"
        },
        {
          "role": "F",
          "text": "じゃあ、今日はやめておきます。"
        },
        {
          "role": "N",
          "text": "女の人は、どうしてこのくつを買いませんか。"
        }
      ]
    },
    {
      "file": "n3_q2_09.mp3",
      "segments": [
        {
          "role": "N",
          "text": "会社で、女の人と男の人が話しています。女の人は、どうして今日早く帰りますか。"
        },
        {
          "role": "M",
          "text": "田中さん、今日は早く帰るんだって？体の調子でも悪いの？"
        },
        {
          "role": "F",
          "text": "いえ、元気ですよ。今日は子どもの学校で行事があって、見に行くんです。"
        },
        {
          "role": "M",
          "text": "ああ、それはいいですね。"
        },
        {
          "role": "N",
          "text": "女の人は、どうして今日早く帰りますか。"
        }
      ]
    },
    {
      "file": "n3_q2_10.mp3",
      "segments": [
        {
          "role": "N",
          "text": "男の人と女の人が旅行について話しています。二人は、どうして海ではなく山に行くことにしましたか。"
        },
        {
          "role": "F",
          "text": "夏休みの旅行、海と山、どっちがいい？"
        },
        {
          "role": "M",
          "text": "うーん、海もいいけど、夏の海はすごく混むよね。"
        },
        {
          "role": "F",
          "text": "そうだね。ゆっくりしたいから、静かなところがいいな。"
        },
        {
          "role": "M",
          "text": "じゃあ、山にしよう。涼しいし、人も少ないから。"
        },
        {
          "role": "N",
          "text": "二人は、どうして山に行くことにしましたか。"
        }
      ]
    },
    {
      "file": "n3_q3_07.mp3",
      "segments": [
        {
          "role": "N",
          "text": "スーパーで、店員がアナウンスをしています。"
        },
        {
          "role": "F",
          "text": "本日はご来店ありがとうございます。ただいま、二階の洋服売り場で、セールを行っております。夏物のシャツやズボンが、すべて半額です。また、五時からは、一階の魚売り場でも安くなります。ぜひ、お買い物をお楽しみください。"
        },
        {
          "role": "N",
          "text": "店員は、主に何について話していますか。"
        }
      ]
    },
    {
      "file": "n3_q3_08.mp3",
      "segments": [
        {
          "role": "N",
          "text": "テレビで、医者が話しています。"
        },
        {
          "role": "M",
          "text": "よく眠るためには、寝る前の過ごし方が大切です。寝る直前までスマートフォンを見ていると、脳が起きてしまって、なかなか眠れません。寝る一時間前には画面を見るのをやめて、部屋を少し暗くしましょう。そうすると、自然に眠くなってきます。"
        },
        {
          "role": "N",
          "text": "医者は、主に何について話していますか。"
        }
      ]
    },
    {
      "file": "n3_q3_09.mp3",
      "segments": [
        {
          "role": "N",
          "text": "会社で、社長が新入社員に話しています。"
        },
        {
          "role": "M",
          "text": "仕事では、失敗することもあります。でも、失敗そのものより、そのあとどうするかが大切です。失敗したら、なぜそうなったのかを考え、次に同じことをしないようにする。それができる人が、少しずつ成長していきます。だから、失敗を怖がらないでください。"
        },
        {
          "role": "N",
          "text": "社長が一番言いたいことは、何ですか。"
        }
      ]
    },
    {
      "file": "n3_q3_10.mp3",
      "segments": [
        {
          "role": "N",
          "text": "ラジオで、男の人が町について話しています。"
        },
        {
          "role": "M",
          "text": "私の町では、五年前から、みんなで花を植える活動を続けています。駅の前や公園に、季節ごとの花を植えるんです。始めたころは数人でしたが、今では子どもからお年寄りまで、たくさんの人が参加しています。花のおかげで町が明るくなり、住む人どうしの会話も増えました。"
        },
        {
          "role": "N",
          "text": "男の人は、主に何について話していますか。"
        }
      ]
    }
  ]
}